{
  "expo": {
    "name": "Ahumados Al Barril",
    "slug": "asados-en-el-barril",
    "version": "1.0.3",
    "jsEngine": "jsc",
    "entryPoint": "./index.js",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.asadosenelbarril.mobile",
      "versionCode": 4,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "splash": {
      "backgroundColor": "#f5efe8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear el código QR para conectar con el servidor.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "25808fb1-de0c-46de-97ce-c9580d10d199"
      }
    },
    "owner": "khaian2"
  }
}
